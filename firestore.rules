rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /boards/{boardId} {
      allow read, write: if request.auth != null
        && request.auth.token.email in [
          'jinwoosuk@his.sc.kr',
          'teacher1@his.sc.kr',
          'teacher2@his.sc.kr'
        ];
    }
  }
}